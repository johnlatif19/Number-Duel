{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/create-room",
      "dest": "/public/create-room.html"
    },
    {
      "src": "/enter-room",
      "dest": "/public/enter-room.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
